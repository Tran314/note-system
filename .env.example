# 数据库
# 警告: 生产环境必须使用强密码! 建议使用密码管理器生成至少16位随机密码
DB_USER=noteuser
DB_PASSWORD=CHANGE_ME_TO_STRONG_PASSWORD_MIN_16_CHARS
DB_NAME=notesystem
DB_PORT=5432

# Redis
# 警告: 生产环境必须使用强密码! 建议使用至少32位随机字符串
REDIS_PASSWORD=CHANGE_ME_TO_STRONG_PASSWORD_MIN_32_CHARS
REDIS_PORT=6379

# JWT
# 警告: 生产环境必须使用强随机密钥! 
# 生成方式: openssl rand -hex 32
# 必须至少64个字符(32字节十六进制)
JWT_SECRET=CHANGE_ME_TO_RANDOM_64_CHARS_HEX_STRING_USE_OPENSSL_RAND_HEX_32
JWT_ACCESS_EXPIRES_IN=1800
JWT_REFRESH_EXPIRES_IN=604800

# 应用
BACKEND_PORT=3001
FRONTEND_PORT=3000
NODE_ENV=development

# 安全配置
# CORS允许的源，多个用逗号分隔
ALLOWED_ORIGINS=http://localhost:3000
# API速率限制配置
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# 文件上传
# 文件大小限制（字节）默认10MB
MAX_FILE_SIZE=10485760
# 上传目录
UPLOAD_DIR=./uploads
# 每个用户最多文件数量
MAX_FILES_PER_USER=1000

# Docker
DOCKER_USERNAME=your-docker-username
