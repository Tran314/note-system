# Note System Environment Variables Template
# Copy this file to .env and fill in your values

# ==================== Database ====================
DB_USER=noteuser
DB_PASSWORD=notepass123
DB_NAME=notesystem
DB_PORT=5432

# PostgreSQL Connection URL (auto-generated from above)
# DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@postgres:5432/${DB_NAME}?schema=public

# ==================== Redis ====================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=redispass123

# ==================== JWT ====================
# Generate a strong secret: openssl rand -base64 32
JWT_SECRET=change-this-to-a-strong-random-string-in-production
JWT_ACCESS_EXPIRES_IN=1800        # 30 minutes
JWT_REFRESH_EXPIRES_IN=604800     # 7 days

# ==================== Ports ====================
FRONTEND_PORT=3000
BACKEND_PORT=3001

# ==================== Docker Hub (for deployment) ====================
DOCKER_USERNAME=your-docker-username

# ==================== Server (for deployment) ====================
SERVER_HOST=your-server-ip
SERVER_USER=root