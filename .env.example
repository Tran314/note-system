# Nebula Environment Variables Template
# Copy this file to .env.local and fill in your values
# Note: .env.local is not committed to git

# ==================== Tencent COS ====================
# Get these from Tencent Cloud Console
VITE_COS_BUCKET=your-bucket-name
VITE_COS_REGION=ap-guangzhou
VITE_COS_SECRET_ID=your-secret-id-here
VITE_COS_SECRET_KEY=your-secret-key-here

# ==================== User Configuration ====================
# Default user ID for local-first architecture
VITE_DEFAULT_USER_ID=anonymous-user

# ==================== Development ====================
# Vite dev server port
VITE_PORT=3000
